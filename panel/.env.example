# ===== Base de datos compartida con el bot =====
# Ruta al archivo SQLite del bot. Por defecto el panel asume que vive en
# bot-nefertiti/panel/ y que la DB está en bot-nefertiti/data/nefertiti.db.
PANEL_DB_PATH=../data/nefertiti.db

# ===== Seguridad de sesión =====
# Clave secreta para firmar la cookie de sesión. Generá una larga y aleatoria:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
PANEL_SESSION_SECRET=cambiame-por-una-clave-larga-y-aleatoria

# Horas de validez de la sesión si NO se marca "mantener sesión iniciada".
PANEL_SESSION_HORAS=12
# Horas si SÍ se marca "mantener sesión iniciada" (por defecto 30 días).
PANEL_SESSION_HORAS_RECORDAR=720

# ===== Puente con el bot de WhatsApp =====
# Debe coincidir con el del .env del bot (PANEL_BRIDGE_*).
BOT_BRIDGE_URL=http://127.0.0.1:3100
PANEL_BRIDGE_TOKEN=cambiame-igual-que-en-el-bot
