# ===== Base de datos =====
DB_PATH=./data/nefertiti.db

# ===== Chromium (VPS) =====
# Ruta del binario de Chromium del sistema. En local dejar vacío para que
# Puppeteer use el Chromium que descarga automáticamente.
CHROMIUM_PATH=

# ===== Horarios =====
HORA_APERTURA=10
HORA_CIERRE_SEMANA=22
HORA_CIERRE_FINDE=23
MINUTOS_AVISO_CIERRE=5

# ===== Aviso de apertura no hecha (minutos después de HORA_APERTURA) =====
APERTURA_AVISAR_ADMIN_MIN=30

# ===== Timeouts de cierre (minutos después del cierre del local) =====
CIERRE_INSISTIR_MIN=15
CIERRE_AVISAR_ADMIN_MIN=25

# ===== Resumen diario al admin (minutos después del cierre del local; =====
# ===== puede ser > 60 y cruzar la medianoche, ej. 90 min después de las 23:00) =====
RESUMEN_OFFSET_MIN=90

# ===== Limpieza de estados inactivos (minutos) =====
ESTADO_TIMEOUT_MIN=30

# ===== Personas (números de WhatsApp en formato internacional sin +) =====
ADMIN_NUMBER=549XXXXXXXXXX
EMPLEADO_X_NUMBER=549XXXXXXXXXX
EMPLEADO_Y_NUMBER=549XXXXXXXXXX

# ===== Nombres mostrados =====
ADMIN_NOMBRE=Admin
EMPLEADO_X_NOMBRE=Empleado X
EMPLEADO_Y_NOMBRE=Empleado Y

# ===== Cajas =====
CANTIDAD_CAJAS=2

# ===== Sesión WhatsApp =====
SESSION_PATH=./session

# ===== Puente con el panel de gestión (Next.js) =====
# Token compartido entre el bot y el panel. Generá uno largo y aleatorio:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Debe ser EXACTAMENTE el mismo en el .env del panel (PANEL_BRIDGE_TOKEN).
# Si se deja vacío, el puente NO se inicia (el panel no podrá avisar a clientes).
PANEL_BRIDGE_TOKEN=
# Puerto y host donde escucha el puente. 127.0.0.1 = solo accesible localmente
# (recomendado en el VPS, panel y bot en la misma máquina).
PANEL_BRIDGE_PORT=3100
PANEL_BRIDGE_HOST=127.0.0.1
